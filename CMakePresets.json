{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "MDE_BUILD_TESTS": "ON",
                "MDE_BUILD_BENCH": "OFF"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MDE_BUILD_TESTS": "OFF",
                "MDE_BUILD_BENCH": "OFF"
            }
        },
        {
            "name": "bench",
            "displayName": "Benchmark",
            "binaryDir": "${sourceDir}/build/bench",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MDE_BUILD_TESTS": "OFF",
                "MDE_BUILD_BENCH": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "bench",
            "configurePreset": "bench"
        }
    ]
}
